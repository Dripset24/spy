    if fBull and aBull and sBull
        result:="BULL F+A+S"
    else if fBear and aBear and sBear
        result:="BEAR F+A+S"
    else if fBull and aBull
        result:="BULL F+A"
    else if aBull and sBull
        result:="BULL A+S"
    else if fBull and sBull
        result:="BULL F+S"
    else if fBear and aBear
        result:="BEAR F+A"
    else if aBear and sBear
        result:="BEAR A+S"
    else if fBear and sBear

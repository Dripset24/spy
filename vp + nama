//=== FUNCTIONS ===
nama(src, len) =>
    goldenRatio = 1.618
    alpha = goldenRatio / 100
    ma = ta.sma(src, len)
    ma := na(ma[1]) ? ma : alpha * src + (1 - alpha) * ma[1]
    ma

dmiCalc(len) =>
    upMove = high - high[1]
    downMove = low[1] - low
    plusDM = (upMove > downMove and upMove > 0) ? upMove : 0.0
    minusDM = (downMove > upMove and downMove > 0) ? downMove : 0.0
    trRma = ta.rma(ta.tr(true), len)
    plus = 100 * ta.rma(plusDM, len) / math.max(trRma, 1e-10)
    minus = 100 * ta.rma(minusDM, len) / math.max(trRma, 1e-10)
    dx = 100 * math.abs(plus - minus) / math.max(plus + minus, 1e-10)
    adx = ta.rma(dx, len)
    [plus, minus, adx]

vfiCalc(len, coef, volCap) =>
    typical = hlc3
    inter = math.log(typical) - math.log(typical[1])
    cutoff = coef * ta.stdev(inter, len) * close
    volAvg = ta.sma(volume, len)
    maxVol = volAvg * volCap
    cappedVol = math.min(volume, maxVol)
    mf = typical - typical[1]
    dir = mf > cutoff ? 1.0 : mf < -cutoff ? -1.0 : 0.0
    raw = dir * cappedVol
    ta.sma((ta.sma(raw, len) * len) / math.max(volAvg, 1e-10), 3)

pine_supertrend(factor, atr) =>
    src = hl2
    upperBand = src + factor * atr
    lowerBand = src - factor * atr
    prevLowerBand = nz(lowerBand[1])
    prevUpperBand = nz(upperBand[1])
    lowerBand := lowerBand > prevLowerBand or close[1] < prevLowerBand ? lowerBand : prevLowerBand
    upperBand := upperBand < prevUpperBand or close[1] > prevUpperBand ? upperBand : prevUpperBand
    int _direction = na
    float superTrend = na
    prevSuperTrend = superTrend[1]
    if na(atr[1])
        _direction := 1
    else if prevSuperTrend == prevUpperBand
        _direction := close > upperBand ? -1 : 1
    else
        _direction := close < lowerBand ? 1 : -1
    superTrend := _direction == -1 ? lowerBand : upperBand
    [superTrend, _direction]

cloudPercentage(price, top, bot) =>
    cloudHeight = top - bot
    priceInCloud = price - bot
    percentage = (priceInCloud / cloudHeight) * 100
    percentage

